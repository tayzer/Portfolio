@page "/project/{ProjectId}"
@inject ProjectService ProjectSvc

@if (isLoading)
{
    <p>Loading project...</p>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <p>@errorMessage</p>
}
else if (project == null)
{
    <p>Project not found.</p>
}
else
{
    <h1>@project.Title</h1>
    <img src="@project.ImageUrl" alt="@project.Title" loading="lazy" decoding="async" style="width:100%; max-width: 600px;" />

    <h2>Summary</h2>
    <p>@project.Summary</p>

    <h2>Technologies Used</h2>
    <ul>
        @foreach (var tech in project.Technologies)
        {
            <li>@tech</li>
        }
    </ul>

    @if (!string.IsNullOrWhiteSpace(project.Challenge))
    {
        <h2>Challenges & Solutions</h2>
        <p>@project.Challenge</p>
    }

    @if (!string.IsNullOrWhiteSpace(project.LiveUrl) || !string.IsNullOrWhiteSpace(project.RepoUrl))
    {
        <p>
            @if (!string.IsNullOrWhiteSpace(project.LiveUrl))
            {
                <a href="@project.LiveUrl" target="_blank" rel="noopener noreferrer">View Live Site</a>
            }
            @if (!string.IsNullOrWhiteSpace(project.LiveUrl) && !string.IsNullOrWhiteSpace(project.RepoUrl))
            {
                <span> | </span>
            }
            @if (!string.IsNullOrWhiteSpace(project.RepoUrl))
            {
                <a href="@project.RepoUrl" target="_blank" rel="noopener noreferrer">View Source Code</a>
            }
        </p>
    }
}

@code {
    [Parameter]
    public string? ProjectId { get; set; }

    private Project? project;
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrWhiteSpace(ProjectId))
        {
            errorMessage = "Project id is missing.";
            isLoading = false;
            return;
        }

        try
        {
            project = await ProjectSvc.GetProjectByIdAsync(ProjectId);
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load project: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}
