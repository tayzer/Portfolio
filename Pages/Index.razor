@page "/"
@inject HomeContentService HomeContentSvc

@if (isLoading)
{
    <p>Loading...</p>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <p>@errorMessage</p>
}
else if (content == null)
{
    <p>Home content unavailable.</p>
}
else
{
    <div class="hero-section">
        <img src="@content.HeroImageUrl" alt="@content.HeroImageAlt" />
        
        <h1>@content.HeroGreeting <span class="highlight">@content.HeroName</span></h1>
        
        @foreach (var paragraph in content.HeroParagraphs)
        {
            <p>@((MarkupString)paragraph)</p>
        }
        
        <div style="margin-top: 2rem;">
            <a href="@content.CtaHref" class="btn-primary">@content.CtaText</a>
        </div>
    </div>

    <div class="card">
        <h2>@content.GoalTitle</h2>
        <p>@content.GoalText</p>
    </div>
}

@code {
    private HomeContent? content;
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            content = await HomeContentSvc.GetHomeContentAsync();
            if (content == null)
            {
                errorMessage = "Home content is missing or invalid.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load home content: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}
